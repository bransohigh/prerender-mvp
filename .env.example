HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
RENDER_TIMEOUT_MS=15000
MAX_HTML_BYTES=5000000
MAX_CONCURRENT_RENDERS=2
MAX_QUEUED_RENDERS=20
RENDER_QUEUE_TIMEOUT_MS=10000

# Phase 6 migration note: the old single API_KEY has been replaced by two
# separate keys with separate headers. API_KEY is no longer read anywhere.
#   Admin/project/domain endpoints -> x-admin-api-key -> ADMIN_API_KEY
#   POST /v1/render                -> x-render-api-key -> RENDER_API_KEY
# Both must be at least 32 characters.
ADMIN_API_KEY=change-me-admin-key-min-32-characters
RENDER_API_KEY=change-me-render-key-min-32-characters

DATABASE_URL=postgres://prerender:prerender-dev-only@localhost:5432/prerender_dev
