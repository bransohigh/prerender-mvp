HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
RENDER_TIMEOUT_MS=15000
MAX_HTML_BYTES=5000000
MAX_CONCURRENT_RENDERS=2
MAX_QUEUED_RENDERS=20
RENDER_QUEUE_TIMEOUT_MS=10000

DATABASE_URL=postgres://prerender:prerender-dev-only@localhost:5432/prerender_dev

# Better Auth (see AUTHENTICATION.md). BETTER_AUTH_SECRET must be at least
# 32 random bytes/characters — generate with `openssl rand -base64 32`.
BETTER_AUTH_SECRET=change-me-at-least-32-random-characters-long
BETTER_AUTH_BASE_URL=http://localhost:3000
# Comma-separated exact origins (no wildcards, HTTPS required in production).
AUTH_TRUSTED_ORIGINS=http://localhost:3000

# Breaking change (Checkpoint 3B): the global ADMIN_API_KEY and
# RENDER_API_KEY env vars, and the x-admin-api-key header, have been
# removed entirely. Management endpoints require a Better Auth browser
# session (see AUTHENTICATION.md); rendering requires a project-scoped
# key created via POST /v1/organizations/:organizationId/projects/:projectId/api-keys,
# sent as the x-render-api-key header. There is no fallback to a global key.

# Process-local rate limits (see SECURITY.md "Rate limiting"). Defaults are
# conservative; all are optional and bounded by src/config/env.ts.
# RENDER_KEY_INVALID_RATE_LIMIT_MAX=20
# RENDER_KEY_INVALID_RATE_LIMIT_WINDOW_MS=60000
# RENDER_KEY_VALID_RATE_LIMIT_MAX=120
# RENDER_KEY_VALID_RATE_LIMIT_WINDOW_MS=60000
# LOGIN_RATE_LIMIT_MAX=10
# LOGIN_RATE_LIMIT_WINDOW_MS=60000
# INVITATION_RATE_LIMIT_MAX=10
# INVITATION_RATE_LIMIT_WINDOW_MS=60000
